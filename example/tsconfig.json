{
    "compilerOptions": {
        "module": "Node16",
        "target": "ES2020",
        "moduleResolution": "node16",
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "strict": true,
        "types": [
            "node"
        ],
        "esModuleInterop": true,
        "skipLibCheck": true,
        "rootDir": "src",
        "outDir": "dist"
    }
}